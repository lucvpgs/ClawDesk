{
  "name": "clawdesk-app",
  "version": "0.6.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --port 3131 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --port 3131 --hostname 0.0.0.0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "tauri:dev": "pnpm tauri dev",
    "tauri:build": "pnpm tauri build",
    "build:desktop": "next build && node scripts/copy-standalone-assets.mjs",
    "deploy:local": "pnpm build:desktop && rsync -a --delete .next/standalone-bundle/ /Applications/ClawDesk.app/Contents/Resources/server/ && codesign --force --deep --sign - /Applications/ClawDesk.app && echo '✅ Deployed to /Applications — restart ClawDesk'",
    "smoke-test": "node scripts/smoke-test-bundle.mjs",
    "build:release": "pnpm build:desktop && pnpm smoke-test",
    "mcp": "node --experimental-strip-types src/mcp/server.mts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@tanstack/react-query": "^5.91.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@tauri-apps/cli"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
