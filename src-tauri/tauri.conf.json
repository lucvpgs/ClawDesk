{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawDesk",
  "version": "0.6.0",
  "identifier": "com.vpgs.clawdesk",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3131",
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm build:desktop"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDNzFGMjM4OUE4MjI1MjUKUldRbEpZS2FPUEp4UEhDWEU3MlpOblVwMHdHSjhRVkRLYWFScDE4RzU3TjdCR2Q1Q2xzUElnbE4K",
      "endpoints": [
        "https://github.com/lucvpgs/ClawDesk/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../.next/standalone-bundle": "server"
    },
    "copyright": "\u00a9 2026 lucvpgs",
    "category": "DeveloperTool",
    "shortDescription": "Mission Control for OpenClaw agents",
    "longDescription": "ClawDesk is a desktop dashboard for managing OpenClaw agents, tasks, schedules, channels, models, and integrations.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0 | libwebkit2gtk-4.0-37",
          "libssl3 | libssl1.1",
          "libgtk-3-0"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}