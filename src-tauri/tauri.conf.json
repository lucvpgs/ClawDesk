{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawDesk",
  "version": "0.4.0",
  "identifier": "com.vpgs.clawdesk",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3131",
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm build:desktop"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../.next/standalone-bundle": "server"
    },
    "copyright": "© 2026 lucvpgs",
    "category": "DeveloperTool",
    "shortDescription": "Mission Control for OpenClaw agents",
    "longDescription": "ClawDesk is a desktop dashboard for managing OpenClaw agents, tasks, schedules, channels, models, and integrations.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
